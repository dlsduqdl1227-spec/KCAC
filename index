/* ═══════════════ 타이머 ═══════════════ */
function startTimer(id, secs) {
  if (S.timers[id]) return;
  if (S.timerSec[id] === undefined) S.timerSec[id] = secs;
  S.timers[id] = setInterval(() => {
    S.timerSec[id]--;
    const el = document.getElementById(id + '-timer');
    if (!el) { stopTimer(id); return; }
    const m = Math.floor(S.timerSec[id] / 60);
    const s = S.timerSec[id] % 60;
    el.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    const thr = id === 'sensory' ? 30 : 60;
    const urgent = S.timerSec[id] <= thr;
    const warn   = S.timerSec[id] <= secs * 0.4;
    el.className = 'timer-val' + (urgent ? ' urgent' : warn ? ' warn' : '');
    if (S.timerSec[id] <= 0) { stopTimer(id); el.textContent = '00:00'; toast('시간이 종료되었습니다.'); }
  }, 1000);
}
function stopTimer(id) {
  if (S.timers[id]) { clearInterval(S.timers[id]); S.timers[id] = null; }
}
function resetTimer(id, secs) {
  stopTimer(id);
  S.timerSec[id] = secs;
  const el = document.getElementById(id + '-timer');
  if (el) {
    const m = Math.floor(secs/60), s = secs%60;
    el.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    el.className = 'timer-val';
  }
}

/* ═══════════════ API ═══════════════ */
async function api(action, data) {
  try {
    const res = await fetch(GAS, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action, ...data }),
    });
    return await res.json();
  } catch(e) { return { ok: false, msg: '네트워크 오류: ' + e.message }; }
}

