function loadVideo() {
  const url = document.getElementById('vis-url')?.value || '';
  const fr  = document.getElementById('video-frame');
  if (!fr || !url) return;
  const yt = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/))([A-Za-z0-9_-]{11})/);
  const gd = url.match(/drive\.google\.com\/file\/d\/([^/]+)/);
  let src = '';
  if (yt) src = `https://www.youtube.com/embed/${yt[1]}?autoplay=1`;
  else if (gd) src = `https://drive.google.com/file/d/${gd[1]}/preview`;
  if (src) fr.innerHTML = `<iframe src="${src}" allowfullscreen allow="autoplay"></iframe>`;
  else toast('YouTube 또는 Google Drive URL만 지원합니다.');
}

