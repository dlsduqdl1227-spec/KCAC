<script>
'use strict';
/* ═══════════════════════════════════════════════════
   KCAC 2026  |  채점 앱 스크립트
═══════════════════════════════════════════════════ */

const GAS = '<?= ScriptApp.getService().getUrl() ?>';

const S = {
  judge:      null,
  scores:     {},
  timers:     {},
  timerSec:   {},
  saved:      {},          // prelim pattern saves
  curPat:     null,
  submitted:  {},
};

/* ═══════════════ 로그인 ═══════════════ */
async function initLogin() {
  const r = await api('getJudgeList', {});
  const el = document.getElementById('judgeListEl');
  if (!r.ok || !r.list?.length) {
    el.innerHTML = '<div style="padding:16px 22px;font-size:12px;color:#999;">명단을 불러올 수 없습니다. 관리자에게 문의하세요.</div>';
    return;
  }
  el.innerHTML = r.list.map(j => {
    const cls = { HEAD:'av-head', VISUAL:'av-visual', TECHNICAL:'av-technical' }[j.role] || 'av-head';
    const initials = j.name.charAt(0);
    return `<div class="judge-item" onclick="fillName('${j.name}')">
      <div class="judge-avatar ${cls}">${initials}</div>
      <div class="judge-name-wrap">
        <div class="judge-nm">${j.name}</div>
        <div class="judge-rl">${j.roleLabel || j.role}</div>
      </div>
      <div class="judge-select-hint">선택</div>
    </div>`;
  }).join('');
}

function fillName(name) {
  document.getElementById('li-name').value = name;
  document.getElementById('li-phone').focus();
}

async function doLogin() {
  const name  = document.getElementById('li-name').value.trim();
  const phone = document.getElementById('li-phone').value.replace(/\D/g,'');
  const errEl = document.getElementById('li-err');
  errEl.textContent = '';

  if (!name)  { errEl.textContent = '이름을 입력해 주세요.'; return; }
  if (!phone) { errEl.textContent = '전화번호를 입력해 주세요.'; return; }

  loading('로그인 중...');
  const r = await api('login', { name, phone });
  loadingOff();

  if (r.ok) {
    S.judge = r.judge;
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('topName').textContent = r.judge.name;
    document.getElementById('topRole').textContent = r.judge.roleLabel || r.judge.role;
    document.getElementById('app').classList.add('visible');
    buildApp();
  } else {
    errEl.textContent = r.msg || '로그인에 실패했습니다.';
  }
}

/* ═══════════════ 앱 빌드 ═══════════════ */
const TAB_MAP = {
  HEAD:      ['prelim','visual','sensory','ranking'],
  VISUAL:    ['prelim','visual','sensory','ranking'],
  TECHNICAL: ['prelim','technical','ranking'],
  ADMIN:     ['prelim','visual','sensory','technical','ranking'],
};
const TAB_INFO = {
  prelim:    { label:'예선',      pill:'패턴' },
  visual:    { label:'결선 패턴', pill:'영상' },
  sensory:   { label:'센서리',    pill:'3분' },
  technical: { label:'테크니컬', pill:'즉시' },
  ranking:   { label:'순위',      pill:null },
};

function buildApp() {
  const role = S.judge.role;
  const tabs = TAB_MAP[role] || TAB_MAP.ADMIN;
  const tbar = document.getElementById('tabbar');
  const pcon = document.getElementById('panels');
  tbar.innerHTML = ''; pcon.innerHTML = '';

  tabs.forEach((id, i) => {
    const m = TAB_INFO[id];
    const t = document.createElement('div');
    t.className = 'tab' + (i === 0 ? ' on' : '');
    t.id = 'tab-' + id;
    t.onclick = () => showTab(id);
    t.innerHTML = m.label + (m.pill ? ` <span class="tab-pill">${m.pill}</span>` : '');
    tbar.appendChild(t);

    const p = document.createElement('div');
    p.className = 'panel' + (i === 0 ? ' on' : '');
    p.id = 'panel-' + id;
    pcon.appendChild(p);
    renderPanel(id);
  });
}

function showTab(id) {
  document.querySelectorAll('.tab').forEach(e => e.classList.remove('on'));
  document.querySelectorAll('.panel').forEach(e => e.classList.remove('on'));
  document.getElementById('tab-' + id)?.classList.add('on');
  const p = document.getElementById('panel-' + id);
  if (p) { p.classList.add('on'); p.scrollTop = 0; }
  if (id === 'ranking') fetchRanking();
}

function renderPanel(id) {
  const p = document.getElementById('panel-' + id);
  if (!p) return;
  const map = {
    prelim:    htmlPrelim,
    visual:    () => htmlVisual(S.judge?.role),
    sensory:   htmlSensory,
    technical: htmlTechnical,
    ranking:   htmlRanking,
  };
  p.innerHTML = (map[id] || (() => ''))();
}

/* ═══════════════ HTML 블록 헬퍼 ═══════════════ */
function sRow(id, name, desc) {
  const btns = [1,2,3,4,5].map(n =>
    `<button class="sb" id="sb-${id}-${n}" onclick="pick('${id}',${n})">${n}</button>`
  ).join('');
  return `<div class="score-row">
    <div class="score-meta">
      <div class="score-name">${name}</div>
      <div class="score-desc">${desc}</div>
    </div>
    <div class="sbg" id="sbg-${id}">${btns}</div>
  </div>`;
}

function pick(id, val) {
  S.scores[id] = val;
  const g = document.getElementById('sbg-' + id);
  if (!g) return;
  g.querySelectorAll('.sb').forEach(b => {
    b.className = 'sb';
    if (+b.textContent === val) b.classList.add('on');
  });
  recalc();
}

function recalc() {
  [
    { ids:['pre-s1','pre-s2','pre-s3'],                                   max:15, tv:'pre-tv', pb:'pre-pb' },
    { ids:['vis-s1','vis-s2','vis-s3','vis-s4','vis-s5','vis-s6'],        max:30, tv:'vis-tv', pb:'vis-pb' },
    { ids:['vis-s1','vis-s2','vis-s3','vis-s4','vis-s5'],                 max:25, tv:'vis-tv', pb:'vis-pb' },  // non-head (overrides above)
    { ids:['sen-s1','sen-s2','sen-s3','sen-s4'],                           max:20, tv:'sen-tv', pb:'sen-pb' },
    { ids:['tec-s1','tec-s2','tec-s3','tec-s4','tec-s5','tec-s6','tec-s7'], max:35, tv:'tec-tv', pb:'tec-pb' },
  ].forEach(g => {
    const tv = document.getElementById(g.tv);
    const pb = document.getElementById(g.pb);
    if (!tv) return;
    const tot = g.ids.reduce((s, id) => s + (S.scores[id] || 0), 0);
    tv.textContent = tot;
    if (pb) pb.style.width = (tot / g.max * 100) + '%';
  });
  // prelim mini-recalc
  const preTot = (S.scores['pre-s1']||0)+(S.scores['pre-s2']||0)+(S.scores['pre-s3']||0);
  const ptv = document.getElementById('pre-tv'); if (ptv) ptv.textContent = preTot;
  const ppb = document.getElementById('pre-pb'); if (ppb) ppb.style.width = (preTot/15*100)+'%';
  updateSavedChips();
}

