  </div>
  <div class="btn-zone" id="pre-submit-zone" style="display:none;">
    <button class="btn btn-primary grow" id="pre-submit-btn" onclick="submitPrelim()">
      전체 제출 — 3패턴 완료
    </button>
  </div>
  <div class="done-block" id="pre-done">
    <div class="done-title">제출 완료</div>
    <div class="done-score" id="pre-done-score"></div>
    <div class="done-sub">예선 채점이 기록되었습니다.</div>
  </div>
</div>`;
}

function selPat(id, name) {
  S.curPat = id;
  document.querySelectorAll('.pat-btn').forEach(b => b.classList.remove('on'));
  document.getElementById('pat-' + id)?.classList.add('on');
  const lbl = document.getElementById('pre-score-lbl');
  if (lbl) lbl.textContent = '채점 — ' + name;

  // 기존 저장값 복원
  const sv = S.saved[id] || {};
  ['s1','s2','s3'].forEach(k => {
    const v = sv[k] || 0;
    S.scores['pre-' + k] = v;
    const g = document.getElementById('sbg-pre-' + k);
    if (!g) return;
    g.querySelectorAll('.sb').forEach(b => {
      b.className = 'sb';
      if (v && +b.textContent === v) b.classList.add('on');
    });
  });
  recalc();
}

function clearPat() {
  if (!S.curPat) { toast('패턴을 먼저 선택하세요.'); return; }
  delete S.saved[S.curPat];
  ['pre-s1','pre-s2','pre-s3'].forEach(id => { S.scores[id] = 0; });
  document.querySelectorAll('#sbg-pre-s1 .sb, #sbg-pre-s2 .sb, #sbg-pre-s3 .sb')
    .forEach(b => b.className = 'sb');
  recalc();
}

function savePat() {
  if (!S.curPat) { toast('패턴을 먼저 선택하세요.'); return; }
  const s1 = S.scores['pre-s1'], s2 = S.scores['pre-s2'], s3 = S.scores['pre-s3'];
  if (!s1||!s2||!s3) { toast('3개 항목을 모두 채점하세요.'); return; }
  S.saved[S.curPat] = { s1, s2, s3 };
  updateSavedChips();
  toast('저장되었습니다.');
}

function updateSavedChips() {
  const nm = { tulip:'튤립', rosetta:'로제타', heart:'하트' };
  Object.entries(nm).forEach(([k,v]) => {
    const el = document.getElementById('sc-' + k);
    if (!el) return;
    if (S.saved[k]) {
      const t = (S.saved[k].s1||0)+(S.saved[k].s2||0)+(S.saved[k].s3||0);
      el.textContent = v + '  ' + t; el.classList.add('ok');
    } else {
      el.textContent = v; el.classList.remove('ok');
    }
  });
  const all3 = Object.keys(S.saved).length >= 3;
  const zone = document.getElementById('pre-submit-zone');
  if (zone) zone.style.display = all3 ? 'flex' : 'none';
}

async function submitPrelim() {
  if (S.submitted.prelim) return;
  const comp = document.getElementById('pre-comp')?.value;
  if (!comp) { toast('참가자 번호를 입력하세요.'); return; }
  if (Object.keys(S.saved).length < 3) { toast('3개 패턴을 모두 저장하세요.'); return; }

  const nm = { tulip:'튤립', rosetta:'로제타', heart:'하트' };
  const ps = Object.entries(S.saved).map(([k,v]) => ({ pattern: nm[k], ...v }));
  const elapsed = 420 - (S.timerSec.prelim ?? 420);

  loading('제출 중...');
  const r = await api('submitPrelim', {
    judgeName: S.judge.name, judgeRole: S.judge.role, judgeRoleLabel: S.judge.roleLabel,
    compNo: comp, round: document.getElementById('pre-round')?.value || 'A조',
    patternScores: ps, elapsedSec: elapsed,
    comment: document.getElementById('pre-comment')?.value || '',
  });
  loadingOff();

  if (r.ok) {
    S.submitted.prelim = true;
    document.getElementById('pre-submit-zone').style.display = 'none';
    document.getElementById('pre-done').classList.add('show');
    document.getElementById('pre-done-score').textContent = r.total + ' / 45점';
    toast('예선 채점이 제출되었습니다.');
  } else { toast(r.msg || '오류가 발생했습니다.'); }
}

