      <option>A조</option><option>B조</option><option>C조</option>
    </select>
  </div>
</div>

<div class="card">
  <div class="sec-label">지정 패턴</div>
  <div class="pat-grid">
    <div class="pat-btn" id="pat-tulip"   onclick="selPat('tulip','튤립')">
      <div class="pat-name">튤립</div><div class="pat-en">Tulip</div>
    </div>
    <div class="pat-btn" id="pat-rosetta" onclick="selPat('rosetta','로제타')">
      <div class="pat-name">로제타</div><div class="pat-en">Rosetta</div>
